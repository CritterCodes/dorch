# Dorch environment variables
# Copy this file to .env and fill in your values before starting

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key — required for codex-cli
OPENAI_API_KEY=

# Anthropic API key — required for claude-cli
ANTHROPIC_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────

# Port for the mobile web UI and API
DORCH_PORT=3000

# ── Agents ────────────────────────────────────────────────────────────────────

# First agent to use when a task starts
DORCH_PRIMARY_AGENT=codex-cli

# Comma-separated rotation list
DORCH_AGENTS=codex-cli,claude-cli

# ── Timeouts ──────────────────────────────────────────────────────────────────

# Milliseconds with no stdout/stderr before triggering a switch (default: 3 min)
DORCH_NO_OUTPUT_TIMEOUT_MS=180000

# Maximum milliseconds a single agent run may last (default: 45 min)
DORCH_MAX_RUNTIME_MS=2700000

# Milliseconds to wait after SIGTERM before sending SIGKILL (default: 5s)
DORCH_KILL_TIMEOUT_MS=5000

# Milliseconds a rate-limited agent must wait before being selected again (default: 90s)
DORCH_RATE_LIMIT_COOLDOWN_MS=90000

# ── Safety limits ─────────────────────────────────────────────────────────────

# Maximum switches before pausing and requiring user input
DORCH_MAX_SWITCHES_PER_TASK=6

# Maximum consecutive failures before pausing
DORCH_MAX_CONSECUTIVE_FAILURES=3

# ── Task / workspace ──────────────────────────────────────────────────────────

# Command to run tests after an agent signals STEP COMPLETE
DORCH_TEST_COMMAND=npm test

# Git branch prefix for task branches
DORCH_TASK_BRANCH_PREFIX=agent/task-

# Path to the memory directory (markdown files)
DORCH_MEMORY_DIR=./data/memory

# Path to the target repo workspace
DORCH_WORKSPACE_DIR=./data/workspace/target-repo

# ── Plan approval ─────────────────────────────────────────────────────────────

# Whether to wait for user approval before starting first agent (always true in MVP)
DORCH_REQUIRE_PLAN_APPROVAL=true

# ── Context limits ────────────────────────────────────────────────────────────

# Maximum combined context chars passed to an agent (approx 8000 tokens)
DORCH_MAX_CONTEXT_CHARS=32000
