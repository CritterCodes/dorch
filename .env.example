# Dorch environment variables
# Copy to .env for local development.

# Required for server startup
DORCH_SESSION_SECRET=
DORCH_SESSION_PASSWORD=

# Optional. Prefer CLI login for normal local use:
#   codex login
#   claude auth login
# Set these only when you intentionally want API-key billing/auth for spawned CLIs.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Server
DORCH_PORT=3000
DORCH_MONGO_URI=mongodb://localhost:27017/dorch
DORCH_SESSION_MAX_AGE_MS=604800000

# Agents
DORCH_PRIMARY_AGENT=codex-cli
DORCH_AGENTS=codex-cli,claude-cli

# Timeouts
DORCH_NO_OUTPUT_TIMEOUT_MS=180000
DORCH_MAX_RUNTIME_MS=2700000
DORCH_KILL_TIMEOUT_MS=5000
DORCH_RATE_LIMIT_COOLDOWN_MS=90000

# Safety limits
DORCH_MAX_SWITCHES_PER_TASK=6
DORCH_MAX_CONSECUTIVE_FAILURES=3

# Workspace and sprint behavior
DORCH_TEST_COMMAND=npm test
DORCH_REQUIRE_PLAN_APPROVAL=true
DORCH_SPRINT_BRANCH_PREFIX=agent/sprint-
DORCH_DEFAULT_REMOTE_TEMPLATE=
DORCH_MAX_CONTEXT_CHARS=32000
